# OpenCode HTTP 服务地址（默认通常是 4096）
# 你在终端运行 `opencode serve` 后，会看到类似：
# opencode server listening on http://127.0.0.1:4096
# 这里就填那条地址。
VITE_OPENCODE_BASE=http://127.0.0.1:4096

# 可选：默认模型（格式必须是 provider/model，例如 deepseek/deepseek-chat）
# 不填也能正常使用，界面发送消息时会走 OpenCode 服务端自己的默认模型。
# 对应的是opencode的config文件种的model
# VITE_OPENCODE_DEFAULT_MODEL=deepseek/deepseek-chat

# 本地 Python memory-worker 地址（前端自动上报 trace）
VITE_MEMORY_WORKER_BASE=http://127.0.0.1:8714

# memory-worker 运行配置（与 .env.local 共用）
OPENCODE_BASE=http://127.0.0.1:4096
OPENCODE_DIRECTORY=
SKILL_WRITE_ROOT=
# analyzer: opencode | mock（mock 便于本地自测）
MW_ANALYZER_MODE=opencode
# writer: opencode | template（template 为本地兜底写法）
MW_WRITER_MODE=opencode
# session strategy: new | fork（默认 new；fork 会从当前任务 session 派生子会话）
MW_SESSION_STRATEGY=new
# memory-worker 创建的 OpenCode 会话标题前缀（前端据此跳过 skill 沉淀）
MW_SESSION_TITLE_PREFIX=[mw-internal]

