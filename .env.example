# =============================================================================
# VibeTrace 环境变量模板（提交到 Git）
#
# 使用：cp .env.example .env.local  后按需修改（.env.local 已 gitignore）
# 读取方：Vite 前端、memory-worker（Python）、OpenCode plugin（agent-cockpit）
# =============================================================================

# -----------------------------------------------------------------------------
# 两种启动方式（二选一）
# -----------------------------------------------------------------------------
#
# 【手动开发】终端自己起 opencode serve（默认 http://127.0.0.1:4096，无密码）：
#   1. cp .env.example .env.local  （或运行 scripts/use-manual-env.ps1）
#   2. 确认 OPENCODE_PROXY_TARGET / OPENCODE_BASE 为 4096
#   3. 不要保留 VITE_OPENCODE_SERVER_PASSWORD 等鉴权行（手动 serve 通常 unsecured）
#   4. npm run worker:py  &&  npm run dev
#
# 【OpenCode 桌面端自动打开 VibeTrace】Plugin 会：
#   - 把 OPENCODE_PROXY_TARGET / OPENCODE_BASE 改成桌面端实际端口（非 4096）
#   - 把桌面端 OPENCODE_SERVER_PASSWORD 写入 .env.local（你无需手填）
#   - 自动重启 Vite，避免浏览器弹出「登录」对话框
#   VIBETRACE_OPENCODE_MODE 会被设为 plugin
#
# 关于浏览器「登录」弹窗：
#   不是 VibeTrace 账号登录，而是 HTTP Basic 鉴权。密码已在 .env.local 里时仍弹窗，
#   几乎总是因为 Vite 在 .env 更新之前就已启动（仍代理旧端口/旧密码）。
#   解决：让 Plugin 自动重启 Vite，或手动关掉 npm run dev 后重开 OpenCode。
#   若填了弹窗：用户名 opencode，密码与 .env.local 里 VITE_OPENCODE_SERVER_PASSWORD 相同即可。

# -----------------------------------------------------------------------------
# OpenCode HTTP — 手动开发默认值（4096）
# -----------------------------------------------------------------------------

# VIBETRACE_OPENCODE_MODE
#   manual：手动手动起 serve；plugin：桌面端 plugin 写入（自动）
VIBETRACE_OPENCODE_MODE=manual

# VITE_OPENCODE_BASE
#   留空 → Vite 同源代理（推荐）。非空 → 浏览器直连该 URL
VITE_OPENCODE_BASE=

# OPENCODE_PROXY_TARGET
#   Vite 把 /session、/global 等转发到此地址。手动开发固定 4096；桌面端由 plugin 改写
OPENCODE_PROXY_TARGET=http://127.0.0.1:4096

# OPENCODE_BASE
#   memory-worker 调 OpenCode 的地址；手动与上一项保持一致
OPENCODE_BASE=http://127.0.0.1:4096

# VITE_OPENCODE_SERVER_PASSWORD / OPENCODE_SERVER_PASSWORD
#   仅桌面端 / 带密码的 opencode serve 需要。手动 unsecured serve 时不要配置（plugin 自动写入）
# VITE_OPENCODE_SERVER_PASSWORD=
# OPENCODE_SERVER_PASSWORD=

# VITE_OPENCODE_SERVER_USERNAME / OPENCODE_SERVER_USERNAME
#   Basic 鉴权用户名，默认 opencode（手动无密码时可省略）
# VITE_OPENCODE_SERVER_USERNAME=opencode
# OPENCODE_SERVER_USERNAME=opencode

# VITE_OPENCODE_DEFAULT_MODEL
#   发消息时默认模型，必须与 OpenCode 一致：provider_id/model_id（中间必须有 /）
#   例：opencode/deepseek-v4-flash-free（错误示例：deepseek-v4-flash-free）
# VITE_OPENCODE_DEFAULT_MODEL=opencode/deepseek-v4-flash-free

# VITE_OPENCODE_DEFAULT_AGENT
#   可选，请求体里的 agent 字段默认值
# VITE_OPENCODE_DEFAULT_AGENT=

# VITE_OPENCODE_DIRECTORY_SEEDS
#   可选，工作区目录种子，逗号分隔的绝对路径列表
# VITE_OPENCODE_DIRECTORY_SEEDS=

# VITE_OPENCODE_FETCH_TIMEOUT_MS
#   OpenCode fetch 超时（毫秒）；≤0 表示不超时；默认 45000
# VITE_OPENCODE_FETCH_TIMEOUT_MS=120000

# -----------------------------------------------------------------------------
# Memory Worker — 前端
# -----------------------------------------------------------------------------

# VITE_MEMORY_WORKER_BASE
#   前端访问 memory-worker 的 URL，例如 http://127.0.0.1:8714
#   留空：与 OpenCode 一样走 Vite 代理（/health、/ingest-trace）
VITE_MEMORY_WORKER_BASE=

# VITE_TRACE_SESSION_TURN_LIMIT
#   ingest 时打包的 session 轮次数（`current_turn` + `history`）
#   默认 5：先放当前轮，再放更早的历史轮
VITE_TRACE_SESSION_TURN_LIMIT=5

# MEMORY_WORKER_PROXY_TARGET（Plugin 自动维护）
#   Vite 转发 memory-worker 的目标，默认 http://127.0.0.1:8714
# MEMORY_WORKER_PROXY_TARGET=http://127.0.0.1:8714

# -----------------------------------------------------------------------------
# Memory Worker — Python（memory_worker/server.py）
# -----------------------------------------------------------------------------

# MEMORY_WORKER_PORT
#   worker 监听端口；未设置时从 VITE_MEMORY_WORKER_BASE 解析，否则默认 8714
# MEMORY_WORKER_PORT=8714

# OPENCODE_DIRECTORY
#   OpenCode 工作目录（x-opencode-directory）；默认项目根
OPENCODE_DIRECTORY=

# SKILL_WRITE_ROOT
#   分析后写入 Skill 文件的根目录；留空 → ~/.claude/skills
#   与 OpenCode 对齐可设：项目/.opencode/skills 或 ~/.config/opencode/skills
SKILL_WRITE_ROOT=

# MW_ANALYZER_MODE
#   trace 分析方式：opencode（走 OpenCode 会话）| mock（本地假数据）
MW_ANALYZER_MODE=opencode

# MW_ANALYZER_SESSION_ATTEMPTS
#   同一 analyzer 会话内最多尝试几轮；仅在「wait stop」超时时同 session 续发，默认 5
# MW_ANALYZER_SESSION_ATTEMPTS=5

# INGEST_DEDUP_FAILED_COOLDOWN_SEC
#   同一 assistant stop  ingest 失败后，多少秒内不再重跑 pipeline（默认 600）
# INGEST_DEDUP_FAILED_COOLDOWN_SEC=600

# MW_WRITER_MODE
#   Skill 写入方式：opencode | template（本地模板兜底）
MW_WRITER_MODE=opencode

# MW_SESSION_STRATEGY
#   调用 OpenCode 时的会话策略：new（新建）| fork（从当前 session 派生）
MW_SESSION_STRATEGY=new

# MW_SESSION_TITLE_PREFIX
#   memory-worker 创建的 OpenCode 会话标题前缀；前端据此跳过 skill 沉淀展示
MW_SESSION_TITLE_PREFIX=[mw-internal]

# MW_CORS_ORIGINS
#   允许跨域访问 worker 的前端来源，分号分隔
MW_CORS_ORIGINS=http://localhost:5173;http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# Plugin / 调试（可选）
# -----------------------------------------------------------------------------

# VIBETRACE_NO_BROWSER
#   设为 1 时 Plugin 不自动打开浏览器
# VIBETRACE_NO_BROWSER=1

# PYTHON
#   启动 memory-worker 时使用的 Python 可执行文件路径（默认 Windows: python，Unix: python3）
# PYTHON=python3

# VITE_DEBUG_VERBOSE_LOGS
#   设为 1 时前端输出更详细的调试日志
# VITE_DEBUG_VERBOSE_LOGS=1
